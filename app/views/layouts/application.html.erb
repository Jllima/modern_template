<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Modern Dashboard | Tailwind & Chakra UI" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Modern Template">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= content_for(:description) || "A premium, modern Rails dashboard template emulating Chakra UI aesthetics with esbuild and Tailwind CSS." %>">
    
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Preconnect to Google Fonts for improved typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- CSS and JS Bundles -->
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>

    <style>
      body {
        font-family: 'Outfit', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      }
    </style>
  </head>

  <body class="h-full bg-slate-50 text-slate-600 antialiased">
    <div data-controller="ui" class="min-h-screen">
      
      <%= render "shared/sidebar" %>

      <div data-ui-target="main" class="flex-1 flex flex-col min-h-screen lg:pl-64 transition-all duration-300">
        <%= render "shared/header" %>

        <main class="flex-grow p-6 md:p-8">
          <%= yield %>
        </main>
      </div>
    </div>
    <%%= turbo_frame_tag "modal" %>
  </body>
</html>
