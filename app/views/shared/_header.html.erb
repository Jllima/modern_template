<header class="h-16 border-b border-slate-100 bg-white px-6 flex items-center justify-between sticky top-0 z-30">
  <div class="flex items-center space-x-4">
    <!-- Hamburger button for mobile -->
    <button 
      type="button" 
      data-action="click->ui#toggleSidebar"
      class="lg:hidden p-2 rounded-chakra-md text-slate-500 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-chakra-brand-500"
      id="mobile-sidebar-toggle"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>

    <!-- Context Breadcrumb / Section Title -->
    <div>
      <span class="text-sm font-medium text-slate-400">Pages</span>
      <span class="text-sm text-slate-300 mx-2">/</span>
      <span class="text-sm font-semibold text-slate-700">Dashboard</span>
    </div>
  </div>

  <div class="flex items-center space-x-4">
    <!-- Search Bar (hidden on small devices) -->
    <div class="relative hidden md:block">
      <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </span>
      <input 
        type="search" 
        placeholder="Search..." 
        class="w-64 bg-slate-50 border border-slate-100 rounded-chakra-lg pl-10 pr-4 py-1.5 text-sm text-slate-600 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-chakra-brand-500 focus:bg-white transition-all duration-150"
      >
    </div>

    <!-- Notification Bell -->
    <button class="p-2 rounded-chakra-lg text-slate-400 hover:text-slate-600 hover:bg-slate-50 transition-colors duration-150 relative">
      <span class="absolute top-1.5 right-1.5 w-2 h-2 rounded-full bg-red-500"></span>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
      </svg>
    </button>

    <!-- Profile Dropdown Container -->
    <div class="relative">
      <button 
        type="button" 
        data-action="click->ui#toggleDropdown"
        class="flex items-center space-x-2 p-1.5 rounded-chakra-lg hover:bg-slate-50 transition-colors duration-150 focus:outline-none"
        id="profile-menu-button"
      >
        <div class="w-8 h-8 rounded-full bg-chakra-brand-100 text-chakra-brand-700 flex items-center justify-center font-semibold text-sm shadow-sm border border-chakra-brand-200">
          JD
        </div>
        <svg class="w-4 h-4 text-slate-400 hidden sm:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </button>

      <!-- Dropdown Menu -->
      <div 
        data-ui-target="dropdown"
        class="absolute right-0 mt-2 w-48 bg-white border border-slate-100 rounded-chakra-xl shadow-chakra-lg py-1 hidden"
        role="menu"
        aria-orientation="vertical"
        aria-labelledby="profile-menu-button"
      >
        <a href="#" class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 transition-colors" role="menuitem">My Profile</a>
        <a href="#" class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 transition-colors" role="menuitem">Account Settings</a>
        <hr class="border-slate-50 my-1">
        <a href="#" class="block px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors font-medium" role="menuitem">Sign Out</a>
      </div>
    </div>
  </div>
</header>
