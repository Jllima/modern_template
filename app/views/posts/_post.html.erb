<tr id="<%= dom_id(post) %>" class="hover:bg-slate-50/50 transition-colors">
  <td class="py-4 px-6"><%= post.title %></td>
  <td class="py-4 px-6"><%= post.desc %></td>
  
  <td class="py-4 px-6 text-right space-x-3">
    <%= link_to "Ver", post, data: { turbo_frame: "modal" }, class: "text-slate-400 hover:text-slate-600 transition-colors font-medium text-sm" %>
    
    <%= link_to "Editar", edit_post_path(post), data: { turbo_frame: "modal" }, class: "text-chakra-brand-500 hover:text-chakra-brand-600 transition-colors font-medium text-sm" %>
  </td>
</tr>