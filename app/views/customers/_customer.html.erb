<tr id="<%= dom_id(customer) %>" class="hover:bg-slate-50/50 transition-colors">
  <td class="py-4 px-6"><%= customer.name %></td>
  <td class="py-4 px-6"><%= customer.email %></td>
  <td class="py-4 px-6"><%= customer.phone %></td>
  
  <td class="py-4 px-6 text-right space-x-3">
    <%= link_to "Ver", customer, data: { turbo_frame: "modal" }, class: "text-slate-400 hover:text-slate-600 transition-colors font-medium text-sm" %>
    
    <%= link_to "Editar", edit_customer_path(customer), data: { turbo_frame: "modal" }, class: "text-chakra-brand-500 hover:text-chakra-brand-600 transition-colors font-medium text-sm" %>
  </td>
</tr>