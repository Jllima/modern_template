<%= form_with(model: customer) do |form| %>
  
  <div class="p-6 space-y-4">
    <% if customer.errors.any? %>
      <div class="p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50 border border-red-200">
        <span class="font-bold"><%= pluralize(customer.errors.count, "error") %> prohibited this from being saved:</span>
        <ul class="mt-1.5 list-disc list-inside">
          <% customer.errors.each do |error| %><li><%= error.full_message %></li><% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :name, class: "block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2" %>
      <%= form.text_field :name, placeholder: "Ex: Enter value...", class: "w-full bg-slate-50 border border-slate-100 rounded-lg px-4 py-2 text-sm text-slate-600 focus:outline-none focus:ring-2 focus:ring-chakra-brand-500 focus:bg-white transition-all duration-150" %>
    </div>
    <div>
      <%= form.label :email, class: "block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2" %>
      <%= form.text_field :email, placeholder: "Ex: Enter value...", class: "w-full bg-slate-50 border border-slate-100 rounded-lg px-4 py-2 text-sm text-slate-600 focus:outline-none focus:ring-2 focus:ring-chakra-brand-500 focus:bg-white transition-all duration-150" %>
    </div>
    <div>
      <%= form.label :phone, class: "block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2" %>
      <%= form.text_field :phone, placeholder: "Ex: Enter value...", class: "w-full bg-slate-50 border border-slate-100 rounded-lg px-4 py-2 text-sm text-slate-600 focus:outline-none focus:ring-2 focus:ring-chakra-brand-500 focus:bg-white transition-all duration-150" %>
    </div>
  </div>

  <div class="p-6 bg-slate-50 border-t border-slate-100 flex items-center justify-end space-x-3">
    <%= link_to "Cancel", customers_path, class: "px-4 py-2 text-sm font-semibold rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-100 transition-colors" %>
    
    <%= form.submit "Salvar", class: "px-4 py-2 text-sm font-semibold rounded-lg bg-chakra-brand-500 hover:bg-chakra-brand-600 text-white transition-colors cursor-pointer" %>
  </div>

<% end %>